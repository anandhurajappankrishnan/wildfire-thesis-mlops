# ── Secrets (never commit .env) ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Required for GEE extraction (step 1)
EE_PROJECT_ID=your-gee-project-id

# Optional: dashboard Gemini assistant (dashboard/app.py)
GEMINI_API_KEY=your-gemini-api-key

# Optional: load bronze layer into SQL Server (step 2b; skips if unset)
SQLSERVER_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=WildfireThesis;Trusted_Connection=yes;
